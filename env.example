# E2E provider tokens — copy this file to .env and fill in what you have:
#
#   cp env.example .env
#
# .env is gitignored AND dockerignored: it never gets committed and never gets
# baked into the E2E image (tokens reach test containers only as runtime env).
# `just` loads .env automatically (set dotenv-load), so `just e2e-tests` picks
# these up with no shell exports. A provider whose token is missing makes that
# provider's live E2E tests FAIL with guidance — by design, never skipped.

# Claude Code (live E2E for the `claude` provider + its judge calls).
# Get one: run `claude setup-token` in a terminal and paste the result here.
CLAUDE_CODE_OAUTH_TOKEN=

# Codex (live E2E for the `codex` provider).
# Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenCode's anthropic provider (live E2E for the `opencode` provider).
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
